rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to validate standard IDs (ID Poisoning Guard)
    function isValidId(id) {
      return id is string 
        && id.size() > 0 
        && id.size() <= 128 
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate user schema (Validation Blueprint / Anti-Update-Gap)
    function isValidUser(userId, data) {
      return data.keys().hasAll(['uid', 'email', 'enrolledCourses', 'savedSites', 'balance', 'createdAt'])
        && data.keys().size() >= 6 
        && data.keys().size() <= 8
        && data.uid == userId
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 254
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 128))
        && data.enrolledCourses is list
        && data.enrolledCourses.size() <= 100
        && (data.enrolledCourses.size() == 0 || data.enrolledCourses[0] is string)
        && (!data.keys().hasAny(['activeSubscription']) || (data.activeSubscription is string && data.activeSubscription.size() <= 128))
        && data.savedSites is list
        && data.savedSites.size() <= 100
        && (data.savedSites.size() == 0 || data.savedSites[0] is string)
        && data.balance is number
        && data.createdAt is string;
    }

    // Helper to validate receipt schema (Validation Blueprint / Anti-Update-Gap)
    function isValidReceipt(receiptId, data) {
      return data.keys().hasAll(['id', 'userId', 'itemType', 'itemId', 'itemName', 'amount', 'timestamp', 'cardLast4', 'status'])
        && data.keys().size() == 9
        && data.id == receiptId
        && data.userId == request.auth.uid
        && data.itemType is string 
        && (data.itemType == 'course' || data.itemType == 'subscription')
        && data.itemId is string
        && data.itemId.size() <= 128
        && data.itemName is string
        && data.itemName.size() <= 256
        && data.amount is number
        && data.timestamp is string
        && data.cardLast4 is string
        && data.cardLast4.size() == 4
        && data.status is string 
        && (data.status == 'success' || data.status == 'failed');
    }

    // Match users collection (PII Isolation and Tiered Identity Logic)
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false; // Strict PII Isolation - no bulk collection scanning
      
      allow create: if request.auth != null 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(userId, request.resource.data);
        
      allow update: if request.auth != null 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(userId, request.resource.data)
        // Ensure immutable values cannot be updated
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt;
        
      allow delete: if false; // Lock out account deletions from client
    }

    // Match receipts collection (Query Enforcer and Write Once policy)
    match /receipts/{receiptId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid; // Secure query enforcer
      
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && isValidId(receiptId)
        && isValidReceipt(receiptId, request.resource.data);
        
      allow update, delete: if false; // Receipts are strictly read-only after write
    }
  }
}
